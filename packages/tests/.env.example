# ===========================================
# BIZZ QUIZ PLATFORM - ENVIRONMENT VARIABLES
# ===========================================

# -------------------------------------------
# DATABASE CONFIGURATION (REQUIRED)
# -------------------------------------------
# PostgreSQL connection string for connection pooling
# For Supabase: postgresql://postgres.[PROJECT]:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user:password@localhost:5432/bizz_dev?schema=public"

# Direct database connection (required for migrations)
# For Supabase: postgresql://postgres.[PROJECT]:[PASSWORD]@[HOST]:5432/postgres
DIRECT_URL="postgresql://user:password@localhost:5432/bizz_dev"

# -------------------------------------------
# AUTHENTICATION (REQUIRED FOR PRODUCTION)
# -------------------------------------------
# NextAuth Configuration
# NEXTAUTH_URL: Your deployed URL (e.g., https://yourdomain.com)
# Local: http://localhost:3000
# Vercel Preview: Will be auto-set by Vercel
# Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# NEXTAUTH_SECRET: Generate with: openssl rand -base64 32
# CRITICAL: MUST be set in production for session security
NEXTAUTH_SECRET=your-secret-key-minimum-32-characters-long = qsTt0BYQ2togETYIL9aDC1Ls8PLV3oLd6dwhgx2Nny8=

# -------------------------------------------
# WALLET & ENCRYPTION (REQUIRED)
# -------------------------------------------
# Encryption key for custodial wallets (AES-256)
# Generate with: openssl rand -hex 32
# CRITICAL: Keep secure, used to encrypt user wallet mnemonics
WALLET_ENCRYPTION_KEY=your-wallet-encryption-key-64-hex-characters

# Encryption key for reveal data (can be same as WALLET_ENCRYPTION_KEY)
REVEAL_DATA_KEY=your-reveal-data-encryption-key-64-hex-characters

# Shared mnemonic for custodial wallet system
# DEVELOPMENT ONLY - Generate unique mnemonics per user in production
BITCOIN_COMPUTER_MNEMONIC="your twelve word mnemonic phrase here for development"

# -------------------------------------------
# BITCOIN COMPUTER BLOCKCHAIN
# -------------------------------------------
NEXT_PUBLIC_BITCOIN_COMPUTER_NETWORK=regtest
NEXT_PUBLIC_BITCOIN_COMPUTER_CHAIN=LTC
NEXT_PUBLIC_BITCOIN_COMPUTER_URL=https://rltc.node.bitcoincomputer.io

# -------------------------------------------
# IPFS CONFIGURATION (REQUIRED)
# -------------------------------------------
# Pinata JWT Token - Get from: https://app.pinata.cloud/keys
# REQUIRED for uploading quiz questions to IPFS
PINATA_JWT=your_pinata_jwt_token_here

# Alternative Pinata credentials (optional if JWT is set)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Public IPFS Gateway for retrieving content
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# -------------------------------------------
# PLATFORM CONFIGURATION
# -------------------------------------------
NEXT_PUBLIC_PLATFORM_FEE=0.02
NEXT_PUBLIC_MIN_ENTRY_FEE=5000
NEXT_PUBLIC_APP_NAME=Bizz

# -------------------------------------------
# REVEAL TIME WINDOWS (CONFIGURABLE)
# -------------------------------------------
# Time windows in minutes
# Development: 5 minutes for quick testing
# Production: 1440 minutes (24 hours) recommended
STUDENT_REVEAL_WINDOW_MINUTES=5
TEACHER_REVEAL_WINDOW_MINUTES=5

# -------------------------------------------
# INDEXER CONFIGURATION (OPTIONAL)
# -------------------------------------------
INDEXER_POLL_INTERVAL=30000
INDEXER_BATCH_SIZE=100

# -------------------------------------------
# ENVIRONMENT
# -------------------------------------------
NODE_ENV=development

