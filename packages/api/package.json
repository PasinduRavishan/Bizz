{
  "name": "@bizz/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services/*": {
      "import": "./dist/services/*.js",
      "types": "./dist/services/*.d.ts"
    },
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bizz/sdk": "*",
    "@bizz/database": "*",
    "@bizz/shared": "*",
    "@bizz/contracts": "*",
    "@bitcoin-computer/lib": "^0.26.0-beta.0",
    "ipfs-http-client": "^60.0.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/crypto-js": "^4.2.2",
    "typescript": "^5"
  }
}
