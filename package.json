{
  "name": "bizz-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @bizz/web",
    "build": "npm run build -w @bizz/contracts && npm run build -w @bizz/web",
    "start": "npm run start -w @bizz/web",
    "lint": "npm run lint --workspaces",
    "test": "npm run test -w @bizz/tests",
    "test:swap": "npm run test:swap -w @bizz/tests",
    "test:flow": "npm run test:flow -w @bizz/tests",
    "test:watch": "npm run test:watch -w @bizz/tests",
    "db:generate": "npm run db:generate -w @bizz/web",
    "db:migrate": "npm run db:migrate -w @bizz/web",
    "db:studio": "npm run db:studio -w @bizz/web",
    "db:push": "npm run db:push -w @bizz/web",
    "indexer": "npm run indexer -w @bizz/web",
    "indexer:once": "npm run indexer:once -w @bizz/web",
    "indexer:status": "npm run indexer:status -w @bizz/web",
    "clean": "rm -rf packages/*/node_modules packages/*/.next packages/*/dist node_modules"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
