# Database Configuration

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/bizz_dev?schema=public"

# For production, use a hosted PostgreSQL service like:
# - Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# - Neon: postgresql://[USER]:[PASSWORD]@[HOST]/[DATABASE]
# - Railway: postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/railway

# Bitcoin Computer Configuration
NEXT_PUBLIC_BITCOIN_COMPUTER_NETWORK=regtest
NEXT_PUBLIC_BITCOIN_COMPUTER_CHAIN=LTC
NEXT_PUBLIC_BITCOIN_COMPUTER_URL=https://rltc.node.bitcoincomputer.io

# Platform Configuration
NEXT_PUBLIC_PLATFORM_FEE=0.02
NEXT_PUBLIC_MIN_ENTRY_FEE=5000

# IPFS Configuration (optional)
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/
IPFS_API_URL=http://localhost:5001

# Indexer Configuration
INDEXER_POLL_INTERVAL=30000
INDEXER_BATCH_SIZE=100

# API Configuration
API_SECRET_KEY=your-secret-key-here-change-in-production

# Development
NODE_ENV=development
